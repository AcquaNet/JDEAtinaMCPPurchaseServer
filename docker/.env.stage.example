# Plantilla para docker/.env.stage (gitignored -- copiar y completar con valores reales).
#   cp .env.stage.example .env.stage
#   docker compose --profile stage --env-file .env.stage up -d
#
# Ambiente STAGE: sin Caddy/dominio publico todavia (ver docker-compose.yml). Los
# servicios quedan atados a 127.0.0.1 -- se llega por SSH tunnel o desde el mismo host.

KC_DB_PASSWORD=changeme_replace_me
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=changeme_replace_me
OPENBAO_ROOT_TOKEN=changeme_replace_me_or_use_a_scoped_token

KC_HOSTNAME=http://localhost:8180
KC_PORT=8180
BAO_PORT=8200
MCP_SERVER_PORT=8080

# LIMITACION: con este issuer interno, el login OAuth completo por browser no va a
# funcionar (Keycloak firma "iss" con KC_HOSTNAME=http://localhost:8180, que no
# coincide). Este ambiente sirve para probar tools con el bypass de token de Atina
# (HS256). El dia que stage tenga su propio dominio publico, agregar Caddy (como
# prod) y apuntar KC_HOSTNAME + MCP_KEYCLOAK_ISSUER_URI a ese dominio.
SPRING_PROFILES_ACTIVE=stage
MCP_KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/jde-integration
BAO_ADDR=http://openbao:8200
BAO_TOKEN=changeme_replace_me_or_use_a_scoped_token

# Secreto compartido con el microservicio de Atina para validar sus JWT HS256.
# Base64 estandar (no URL-safe), min. 32 bytes decodificado. Vacio = tokens de Atina rechazados.
ATINA_JWT_SECRET=

# Mulesoft / Gateway de Atina de stage (host:puerto reales de ese ambiente)
JDE_MULESOFT_BASE_URL=http://CAMBIAR-HOST-MULESOFT-STAGE:8089/api
JDE_ATINA_GATEWAY_BASE_URL=http://CAMBIAR-HOST-GATEWAY-STAGE:8086

# Imagen del MCP Server (dejar el default para buildear localmente con `docker compose build`,
# o apuntar a un tag propio en un registry si stage se despliega desde una imagen publicada)
MCP_IMAGE=jde-mcp-server:stage
