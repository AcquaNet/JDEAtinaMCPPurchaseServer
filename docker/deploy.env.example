# Plantilla para docker/deploy.env (gitignored -- copiar y completar con los datos
# reales del droplet de Digital Ocean).
#   cp deploy.env.example deploy.env
#
# Usado por scripts/deploy.sh para conectarse por SSH.

DO_HOST=CAMBIAR-IP-DEL-DROPLET
DO_USERNAME=root
DO_SSH_KEY_PATH=~/.ssh/id_rsa
# Carpeta del proyecto Docker en el droplet (solo docker/, no hace falta el repo completo)
REMOTE_DIR=/root/jde-mcp-server-docker
