# ============================================================
# JDE MCP Server -- ambiente DEV (docker compose --profile dev)
# ============================================================

# --- Keycloak: admin console ---
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=changeme_admin_password

# --- Keycloak: base de datos (Postgres) ---
KC_DB_PASSWORD=changeme_db_password

# --- OpenBao (vault de credenciales JDE) ---
OPENBAO_ROOT_TOKEN=dev-only-root-token

# --- Puertos publicados al host ---
KC_PORT=8180
BAO_PORT=8200
MCP_SERVER_PORT=8080

# --- Imagen del MCP Server. Default (sin esta variable) es "jde-mcp-server:latest",
# buildeada localmente por "docker compose build". Seteala para usar en cambio una
# imagen ya pusheada a un registry (Parte 3 de DEPLOYMENT.md: build+push acá, "docker
# compose pull mcp-server" en la otra PC).
MCP_IMAGE=92455890/jde-mcp-server:latest

# --- MCP Server: perfil Spring activo ---
SPRING_PROFILES_ACTIVE=dev

# --- OpenBao: usado tanto por el MCP Server en el host (IntelliJ) como por el
# contenedor mcp-server de este compose. BAO_TOKEN en dev coincide con
# OPENBAO_ROOT_TOKEN; en prod usar un token acotado (ver DEPLOYMENT.md).
BAO_ADDR=http://localhost:8200
BAO_TOKEN=dev-only-root-token

# --- Gateway de Atina: TODAS las operaciones de negocio (purchase orders,
# sales order lookup/detail, item search/price) pasan por acá. Corre en OTRO
# docker compose (fuera de este), publicado en el host -- por eso se llega via
# host.docker.internal desde el contenedor mcp-server, no por nombre de servicio.
JDE_ATINA_GATEWAY_BASE_URL=http://host.docker.internal:8086

# --- "Mulesoft": YA NO es el camino principal (todo pasa por el Gateway de
# arriba). Sigue existiendo en el codigo por 2 usos puntuales, ninguno migrado
# al Gateway todavia:
#   1. jde.api.base-url -> login manual a JDE (JdeAuthClient, POST /v1/login).
#      Dead code mientras te autentiques via Keycloak con el claim atina_token
#      (jde.atina.session-source=claim, el default) -- nunca se llama.
#   2. jde.so.api.base-url -> SOLO el tool jde_get_customer_credit_info le
#      pega directo a esto (no al Gateway). Si ya no tenes un Mulesoft real
#      corriendo, ese tool puntual se va a colgar/fallar -- el resto (purchase
#      orders, sales order, items) no depende de esto.
# Evitar jde_get_customer_credit_info en la demo hasta migrarlo al Gateway
# (pendiente, requiere la operacion BSSV equivalente).
JDE_MULESOFT_BASE_URL=http://host.docker.internal:8089/api

# --- Keycloak vía ngrok (demo con login OAuth real, ver DEPLOYMENT.md Parte 2).
# Dejar vacío / sin estas dos líneas si NO estás haciendo la demo con ngrok
# (Keycloak arranca con KC_HOSTNAME=http://localhost:8180 por defecto).
KC_HOSTNAME=https://nonelaborating-angila-cateringly.ngrok-free.dev
MCP_KEYCLOAK_ISSUER_URI=https://nonelaborating-angila-cateringly.ngrok-free.dev/realms/jde-integration

# --- Bypass de Atina (HS256) para probar sin mcp-remote/OAuth (ver DEPLOYMENT.md /
# troubleshooting: mcp-remote se cuelga ~60s pese a que el MCP Server responde rápido).
# Generado localmente solo para diagnosticar -- si el Gateway real de Atina valida la
# firma del token contra su propio secreto, esto NO va a servir para traer datos
# reales de JDE, pero SÍ sirve para probar que el protocolo MCP en sí (initialize,
# tools/list, tools/call) funciona bien sobre el túnel, sin mcp-remote de por medio.
ATINA_JWT_SECRET=123456789012345678901234567890123456789012345678901234567890
