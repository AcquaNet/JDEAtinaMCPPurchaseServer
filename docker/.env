KC_DB_PASSWORD=changeme_db_password
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=changeme_admin_password
OPENBAO_ROOT_TOKEN=dev-only-root-token

# Variables para el MCP Server cuando corre en el HOST via IntelliJ / ./mvnw spring-boot:run
# (no en el compose): exportarlas en el entorno donde corre el server.
# BAO_TOKEN en dev coincide con OPENBAO_ROOT_TOKEN; en prod usar un token acotado.
BAO_ADDR=http://localhost:8200
BAO_TOKEN=dev-only-root-token

# --- Servicio mcp-server del compose (docker compose --profile dev up -d) ---
# Solo necesario si además querés probar la imagen Docker del MCP Server localmente
# (no reemplaza correrlo desde el IDE). "localhost" no sirve DENTRO del contenedor:
# apunta a los servicios hermanos por nombre, y a host.docker.internal si Mulesoft/
# Gateway corren en tu misma maquina.
# LIMITACION: con este MCP_KEYCLOAK_ISSUER_URI interno, el login OAuth completo por
# browser (Claude.ai/Desktop) NO va a funcionar acá (Keycloak firma "iss" con
# KC_HOSTNAME=http://localhost:8180, que no coincide) -- este perfil containerizado
# sirve para probar tools con el bypass de token de Atina (HS256), no el flujo OAuth
# interactivo. Para probar el login real, seguir usando el IDE (ahi "localhost" sí
# es correcto en application-dev.properties).
SPRING_PROFILES_ACTIVE=dev

JDE_MULESOFT_BASE_URL=http://host.docker.internal:8089/api
JDE_ATINA_GATEWAY_BASE_URL=http://host.docker.internal:8086
MCP_SERVER_PORT=8080
KC_PORT=8180
BAO_PORT=8200
# 
# -----------------------------------------------------
# Define donde esta la URL de Keycloak NGROK
# -----------------------------------------------------
#
KC_HOSTNAME=https://nonelaborating-angila-cateringly.ngrok-free.dev
#
MCP_KEYCLOAK_ISSUER_URI=https://nonelaborating-angila-cateringly.ngrok-free.dev/realms/jde-integration
#
