KC_DB_PASSWORD=changeme_db_password
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=changeme_admin_password
OPENBAO_ROOT_TOKEN=dev-only-root-token

# Variables para el MCP Server (corre en el host, no en el compose):
# exportarlas en el entorno donde corre el server (shell / IntelliJ run config).
# BAO_TOKEN en dev coincide con OPENBAO_ROOT_TOKEN; en prod usar un token acotado.
BAO_ADDR=http://localhost:8200
BAO_TOKEN=dev-only-root-token