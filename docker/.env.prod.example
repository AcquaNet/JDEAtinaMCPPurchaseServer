# Plantilla para docker/.env.prod (gitignored -- copiar y completar con valores reales
# antes de desplegar en el droplet de Digital Ocean).
#   cp .env.prod.example .env.prod
#   docker compose --profile prod --env-file .env.prod up -d
#
# Ambiente PROD: Caddy publica 80/443 y obtiene HTTPS de Let's Encrypt automaticamente
# para los dominios de abajo (ver caddy/Caddyfile.prod). Todo lo demas (Keycloak,
# OpenBao, mcp-server) queda atado a 127.0.0.1 -- solo alcanzable por SSH tunnel.
#
# Prerequisito de DNS (registros A apuntando a la IP del droplet):
#   jdemcp-atina-connection.com      -> IP del droplet
#   auth.jdemcp-atina-connection.com -> IP del droplet

KC_DB_PASSWORD=CAMBIAR-password-fuerte
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=CAMBIAR-password-fuerte
OPENBAO_ROOT_TOKEN=CAMBIAR-usar-token-acotado-no-el-root

# URL publica HTTPS de Keycloak (a traves de Caddy) -- la ve el browser del usuario
# durante el login OAuth. (KC_PROXY_HEADERS=xforwarded, para confiar en los
# X-Forwarded-* de Caddy, ya viene fijo en docker-compose.yml -- no hace falta acá.)
KC_HOSTNAME=https://auth.jdemcp-atina-connection.com
KC_PORT=8180
BAO_PORT=8200
MCP_SERVER_PORT=8080

SPRING_PROFILES_ACTIVE=prod

# IMPORTANTE: tiene que ser la URL PUBLICA (igual que KC_HOSTNAME), no la interna
# (http://keycloak:8080). Keycloak firma el claim "iss" de cada token con su propio
# KC_HOSTNAME configurado; si el MCP Server espera un issuer distinto, rechaza TODOS
# los tokens (issuer mismatch). El MCP Server igual puede resolver esta URL (sale por
# Caddy hacia si mismo, "hairpin" normal en un droplet) para el discovery/JWKS -- ver
# nota de rendimiento en docker/README.md si mas adelante conviene desacoplar
# issuer (publico) de jwks-uri (interno, mas rapido) en SecurityConfig.
MCP_KEYCLOAK_ISSUER_URI=https://auth.jdemcp-atina-connection.com/realms/jde-integration

BAO_ADDR=http://openbao:8200
BAO_TOKEN=CAMBIAR-usar-token-acotado-no-el-root

# Secreto compartido con el microservicio de Atina para validar sus JWT HS256.
# Base64 estandar (no URL-safe), min. 32 bytes decodificado. Vacio = tokens de Atina rechazados.
ATINA_JWT_SECRET=

# Mulesoft / Gateway de Atina de produccion (host:puerto reales)
JDE_MULESOFT_BASE_URL=http://CAMBIAR-HOST-MULESOFT-PROD:8089/api
JDE_ATINA_GATEWAY_BASE_URL=http://CAMBIAR-HOST-GATEWAY-PROD:8086

# Imagen del MCP Server. Si se buildea y pushea a un registry (recomendado para no
# compilar en el droplet), apuntar al tag real, ej: tuusuario/jde-mcp-server:latest
MCP_IMAGE=jde-mcp-server:prod
